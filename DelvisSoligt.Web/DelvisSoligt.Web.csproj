<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UserSecretsId>f53d1d70-8919-477b-963a-fa41faca99f9</UserSecretsId>
	</PropertyGroup>

	<ItemGroup>
		<Content Remove="wwwroot\Scripts\hejsan.ts" />
		<Content Remove="wwwroot\Scripts\index.ts" />
	</ItemGroup>

	<ItemGroup>
		<UpToDateCheckBuilt Include="wwwroot/lib/tailwindcss/index.css" Set="Css" />
		<UpToDateCheckBuilt Include="tailwind.config.js" Set="Css" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Update="SonarAnalyzer.CSharp" Version="9.20.0.85982" />
	</ItemGroup>

	<ItemGroup>
		<Folder Include="wwwroot\js\dist\" />
	</ItemGroup>

	<ItemGroup>
		<None Include="wwwroot\Scripts\hejsan.ts" />
		<None Include="wwwroot\Scripts\index.ts" />
	</ItemGroup>

	<Target Name="Tailwind" BeforeTargets="Build">
		<Exec Command="npm run build:css" />
	</Target>

	<Target Name="esbuild" BeforeTargets="Tailwind">
		<Exec Command="pnpm run build:js" />
	</Target>
</Project>
