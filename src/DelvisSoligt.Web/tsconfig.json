{
    "compileOnSave": true,
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "allowSyntheticDefaultImports": true,
        "outDir": "./wwwroot/dist",
        "noEmitOnError": true,
        "skipLibCheck": true,
        "target": "es2024",
        "sourceMap": true,
        "strict": true
    },
    "include": [
        "./wwwroot/Scripts/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "wwwroot/dist",
        "**/*.test.ts"
    ]
}
